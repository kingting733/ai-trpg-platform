NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI GM Configuration
# AI_PROVIDER options: deepseek | openai | anthropic
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
AI_API_KEY=your_ai_api_key_here

# Optional: use a more capable model for scenario imports (long documents).
# If unset, falls back to AI_MODEL above.
# AI_IMPORT_MODEL=deepseek-chat-pro

# Optional: max characters of the full story kept as the GM's play-time reference
# (injected into the cached system prefix). Default 100000 (~30-40k tokens).
# AI_SOURCE_DOC_MAX_CHARS=100000
